{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar host local V.A.C.",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\serve.ps1"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "vac",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Iniciando host local",
          "endsPattern": "Host local disponivel em"
        }
      }
    }
  ]
}
